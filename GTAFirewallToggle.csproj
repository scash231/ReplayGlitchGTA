<Project Sdk="Microsoft.NET.Sdk">

  <PropertyGroup>
    <OutputType>WinExe</OutputType>
    <TargetFramework>net8.0-windows</TargetFramework>
    <Nullable>enable</Nullable>
    <UseWindowsForms>true</UseWindowsForms>
    <ImplicitUsings>enable</ImplicitUsings>
    <AssemblyName>WinNetSyncTool</AssemblyName>
    <RootNamespace>WinNetSyncTool</RootNamespace>
  </PropertyGroup>

  <ItemGroup>
    <PackageReference Include="Obfuscar" Version="2.2.50" />
  </ItemGroup>

  <Target Name="Obfuscar" AfterTargets="Build" Condition=" '$(Configuration)' == 'Release' ">
    <Exec Command="$(Obfuscar) obfuscar.xml" WorkingDirectory="$(ProjectDir)" />
  </Target>

</Project>
